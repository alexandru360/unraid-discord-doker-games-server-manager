{
  "ConfigVersion": 3,
  "Discord": {
    "Token": "YOUR_DISCORD_TOKEN_HERE",
    "GuildId": 0
  },
  "Docker": {
    "Endpoint": "unix:///var/run/docker.sock",
    "ManagedContainers": ""
  },
  "Database": {
    "ConnectionString": "Data Source=/data/db/gamemanager.db"
  },
  "Storage": {
    "Root": "/data",
    "DbPath": "/data/db",
    "LogsPath": "/data/logs",
    "ConfigPath": "/data/config"
  },
  "Ollama": {
    "Enabled": false,
    "BaseUrl": "http://localhost:11434",
    "Model": "llama3"
  },
  "Containers": [
    {
      "Name": "minecraft",
      "ContainerId": "Minecraft-Server",
      "Description": "Minecraft Java Server",
      "Game": "Minecraft",
      "IsEnabled": true,
      "PlayerJoinPattern": "\\[.+\\] \\[Server thread/INFO\\]: (.+) joined the game",
      "PlayerLeavePattern": "\\[.+\\] \\[Server thread/INFO\\]: (.+) left the game"
    },
    {
      "Name": "minecraft-bedrock",
      "ContainerId": "Minecraft-Bedrock",
      "Description": "Minecraft Bedrock Server",
      "Game": "Minecraft Bedrock",
      "IsEnabled": true,
      "PlayerJoinPattern": null,
      "PlayerLeavePattern": null
    },
    {
      "Name": "starrupture",
      "ContainerId": "Star-Rupture-with-mods",
      "Description": "StarRupture server",
      "Game": "StarRupture",
      "IsEnabled": true,
      "PlayerJoinPattern": "^LogTemp: Warning: MapUniqueNetIdSteamWithEOS called for PlayerId: (\\d+), Type: .*",
      "PlayerLeavePattern": null
    },
    {
      "Name": "icarus",
      "ContainerId": "Icarus",
      "Description": "Icarus server",
      "Game": "Icarus",
      "IsEnabled": true,
      "PlayerJoinPattern": null,
      "PlayerLeavePattern": null
    },
    {
      "Name": "satisfactory",
      "ContainerId": "Satisfactory",
      "Description": "Satisfactory server",
      "Game": "Satisfactory",
      "IsEnabled": true,
      "PlayerJoinPattern": null,
      "PlayerLeavePattern": null
    },
    {
      "Name": "rust",
      "ContainerId": "RUST",
      "Description": "Rust server",
      "Game": "Rust",
      "IsEnabled": true,
      "PlayerJoinPattern": null,
      "PlayerLeavePattern": null
    },
    {
      "Name": "v-rising",
      "ContainerId": "V-Rising",
      "Description": "V Rising server",
      "Game": "V Rising",
      "IsEnabled": true,
      "PlayerJoinPattern": null,
      "PlayerLeavePattern": null
    }
  ],
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": "Information",
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ],
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "/data/logs/log-.log",
          "rollingInterval": "Day",
          "shared": true
        }
      }
    ]
  }
}
