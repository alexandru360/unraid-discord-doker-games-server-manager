{
  "ConfigVersion": 1,
  "Discord": {
    "Token": "YOUR_DISCORD_TOKEN_HERE",
    "GuildId": 0
  },
  "Docker": {
    "Endpoint": "unix:///var/run/docker.sock"
  },
  "Database": {
    "ConnectionString": "Data Source=/data/db/gamemanager.db"
  },
  "Storage": {
    "Root": "/data",
    "DbPath": "/data/db",
    "LogsPath": "/data/logs",
    "ConfigPath": "/data/config"
  },
  "Ollama": {
    "Enabled": false,
    "BaseUrl": "http://localhost:11434",
    "Model": "llama3"
  },
  "Containers": [
    {
      "Name": "minecraft",
      "ContainerId": "minecraft-server",
      "Description": "Minecraft Java Server",
      "Game": "Minecraft",
      "IsEnabled": true,
      "PlayerJoinPattern": "\\[.+\\] \\[Server thread/INFO\\]: (.+) joined the game",
      "PlayerLeavePattern": "\\[.+\\] \\[Server thread/INFO\\]: (.+) left the game"
    }
  ],
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": "Information",
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ],
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "/data/logs/log-.log",
          "rollingInterval": "Day",
          "shared": true
        }
      }
    ]
  }
}
