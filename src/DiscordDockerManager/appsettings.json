{
  "Discord": {
    "Token": "YOUR_DISCORD_TOKEN_HERE",
    "GuildId": 0
  },
  "Docker": {
    "Endpoint": "unix:///var/run/docker.sock"
  },
  "Database": {
    "ConnectionString": "Data Source=gamemanager.db"
  },
  "Ollama": {
    "Enabled": false,
    "BaseUrl": "http://localhost:11434",
    "Model": "llama3"
  },
  "Containers": [
    {
      "Name": "minecraft",
      "ContainerId": "minecraft-server",
      "Description": "Minecraft Java Server",
      "Game": "Minecraft",
      "IsEnabled": true,
      "PlayerJoinPattern": "\\[.+\\] \\[Server thread/INFO\\]: (.+) joined the game",
      "PlayerLeavePattern": "\\[.+\\] \\[Server thread/INFO\\]: (.+) left the game"
    }
  ],
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
